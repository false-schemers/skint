#!/bin/bash

for arg in "$@"; do
   case $arg in
       --prefix=*)
           PREFIX="${arg#*=}"
           ;;
       --use-unicode)
           USE_UNICODE=1
           ;;
       --use-enhanced-tty)
           USE_ENHTTY=1
           ;;
       *)
           echo "Usage: $0 [--prefix=PATH] [--use-unicode] [--use-enhanced-tty]" >&2
           exit 1
           ;;
   esac
done

echo PREFIX="${PREFIX:-/usr/local}" > config.mk
echo USE_UNICODE="${USE_UNICODE:-0}" >> config.mk 
echo USE_ENHTTY="${USE_ENHTTY:-0}" >> config.mk 
